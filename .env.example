# Copy this file to .env and fill in real values.
# .env is listed in .gitignore and will never be committed to GitHub.
# In GitHub Actions, these are stored as repository Secrets, not here.

# Semantic Scholar — get a free key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_key_here

# Coming soon (future collectors):
# HUGGINGFACE_API_KEY=your_key_here
# GITHUB_API_TOKEN=your_token_here
# REDDIT_CLIENT_ID=your_client_id_here
# REDDIT_CLIENT_SECRET=your_client_secret_here
# REDDIT_USER_AGENT=ai-dashboard/1.0
# (ArXiv, PyPI, Yahoo Finance are also public — no key needed)
